# ============================================================
# Customer environment template
# Copy to customers/<customer_name>/.env and fill in values.
# NEVER commit the filled .env files — add customers/*/.env to .gitignore
# ============================================================

# ── Identity ─────────────────────────────────────────────────
CUSTOMER_NAME=                  # e.g. alkatatib  (no spaces, lowercase)
GITHUB_OWNER=                   # your GitHub org or username

# ── Domains ──────────────────────────────────────────────────
# All three must have DNS A records pointing to this VPS IP
STORE_DOMAIN=                   # e.g. alkatatib.com
ADMIN_DOMAIN=                   # e.g. admin.alkatatib.com
GAME_DOMAIN=                    # e.g. game.alkatatib.com

# ── Database ─────────────────────────────────────────────────
DB_NAME=toystore
DB_USER=toystore
DB_ROOT_PASSWORD=
DB_PASSWORD=

# ── App secrets ──────────────────────────────────────────────
JWT_SECRET=                     # min 32 chars, use: openssl rand -hex 32

# ── Email (Gmail SMTP) ───────────────────────────────────────
MAIL_USERNAME=                  # Gmail address
MAIL_PASSWORD=                  # Gmail App Password (not your login password)

# ── Cloudinary ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
